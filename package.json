{
  "name": "pi-armory",
  "version": "0.2.0",
  "packageManager": "npm@11.12.1",
  "description": "Declarative command tools for pi — structured, pre-approved commands instead of a shell.",
  "license": "MIT",
  "author": "Jonas Damtoft",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jomik/pi-armory.git"
  },
  "homepage": "https://github.com/Jomik/pi-armory",
  "keywords": [
    "pi",
    "agent",
    "tools",
    "sandbox",
    "security"
  ],
  "type": "module",
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": ">=0.74.0",
    "@earendil-works/pi-coding-agent": ">=0.74.0",
    "@earendil-works/pi-tui": ">=0.74.0",
    "typebox": "^1.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@earendil-works/pi-ai": ">=0.74.0",
    "@earendil-works/pi-coding-agent": ">=0.74.0",
    "@earendil-works/pi-tui": ">=0.74.0",
    "typebox": "^1.1.31",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
